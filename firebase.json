{
  "hosting": {
    "public": "public",
    "cleanUrls": true,
    "predeploy": [
      "cp naver1141b796dc8b921333cb22d8a36d78d6.html public/",
      "cp ads.txt public/",
      "cp sitemap.xml public/",
      "cp rss.xml public/"
    ],
    "headers": [
      {
        "source": "/ads.txt",
        "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
      },
      {
        "source": "/sitemap.xml",
        "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
      },
      {
        "source": "/rss.xml",
        "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
      },
      {
        "source": "/robots.txt",
        "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/main_v*.js",
        "destination": "/main.js"
      },
      {
        "source": "!/@(sitemap.xml|rss.xml|robots.txt|ads.txt|naver1141b796dc8b921333cb22d8a36d78d6.html|*.js|*.css|*.png|*.jpg|*.ico|*.svg)",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
