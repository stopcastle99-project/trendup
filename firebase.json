{
  "hosting": {
    "public": "public",
    "cleanUrls": true,
    "predeploy": [
      "cp index.html public/",
      "cp main.js public/",
      "cp main.js public/main_v161.js",
      "cp style.css public/",
      "mkdir -p public/report && cp report/index.html public/report/ && cp report/report.js public/report/",
      "cp naver1141b796dc8b921333cb22d8a36d78d6.html public/",
      "cp ads.txt public/",
      "cp sitemap.xml public/",
      "cp rss.xml public/"
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "/**/*.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "/**/*.css",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "/ads.txt",
        "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
      },
      {
        "source": "/sitemap.xml",
        "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
      },
      {
        "source": "/rss.xml",
        "headers": [{ "key": "Content-Type", "value": "application/xml; charset=utf-8" }]
      },
      {
        "source": "/robots.txt",
        "headers": [{ "key": "Content-Type", "value": "text/plain; charset=utf-8" }]
      }
    ],
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/report/**",
        "destination": "/report/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
