rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /trends/{document=**} {
      allow read: if true;
    }
    match /reports/{type}/{country}/{reportId} {
      allow read: if true;
    }
    match /reports/{type}/{country}/latest {
      allow read: if true;
    }
    match /trend_history/{document=**} {
      allow read: if true;
    }
  }
}
